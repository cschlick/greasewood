# ─────────────────────────────────────────────────────────────────────────────
#  greasewood grant table — the mesh's access policy (grants.toml)
#
#  `gw create` already drops a copy of the DEFAULT (the `* -> * : *` grant
#  below) at <data_dir>/grants.toml on the anchor, and signs it into the
#  distributed policy.json. This file is the fuller reference.
#
#  grants.toml is the SOURCE OF TRUTH: the running anchor watches it and
#  auto-signs edits into policy.json within a sync interval (logging the
#  tunnel delta) — editing this file IS how you change policy, no command
#  needed. `sudo gw policy apply` is the optional preview-and-apply-now path.
#
#  Semantics — allow-only, and the table DERIVES the topology:
#    · a tunnel exists between two nodes iff some grant connects their roles
#      (either direction — tunnels are symmetric; direction matters to port
#      filtering, enforced by default; set enforce_ports=false to opt out)
#    · deleting a grant tears its tunnels down on the next sync + reconcile
#    · a deny rule is NOT expressible — omit the grant instead
#    · hardwired beneath the table, never editable here: every node <-> anchor
#      (the channel that carries this policy must not be prunable by it)
#
#  Roles are CA-signed caps, assigned at invite / set-roles / set-caps:
#      sudo gw invite --roles web            # → role:web (+ default caps)
#      sudo gw set-roles db01 db             # → role:db
#  Roles are the ONLY configured vocabulary. "Segments" are emergent: the
#  unnamed connected structure this table produces (role:client and
#  role:server nodes granted an interface share one; delete the grant and it
#  dissolves). `gw watch --by-role` reports them; nothing configures them.
# ─────────────────────────────────────────────────────────────────────────────

# THE DEFAULT — everything open. This is exactly how a mesh with no policy
# behaves (a flat mesh); it's written out so you edit from a visible baseline.
# Leaving it in keeps the mesh fully open no matter what else you add below.
[[grant]]
from  = ["*"]
to    = ["*"]
ports = ["*"]

# ── To tighten, DELETE the wildcard grant above and use specific grants. ─────
# A worked example (uncomment + adapt to your roles):
#
# [[grant]]
# from  = ["web", "worker"]
# to    = ["api"]
# ports = ["tcp/8000"]
# # why: the app tier calls the API; nothing else does.
#
# [[grant]]
# from  = ["web"]
# to    = ["db"]
# ports = ["tcp/5432"]
# # why: only web reaches postgres — workers go through the API.
#
# [[grant]]
# from  = ["metrics"]
# to    = ["*"]                  # every node
# ports = ["tcp/9100"]
# # why: prometheus scrapes node_exporter fleet-wide (hub-and-spoke tunnels).
