# ─────────────────────────────────────────────────────────────────────────────
#  greasewood grant table — the mesh's access policy (grants.toml)
#
#  `gw create` already drops a DEFAULT-CLOSED grants.toml at <data_dir>/grants.toml
#  on the anchor (the admin-only-SSH grant below) and signs it into the
#  distributed policy.json. This file is the fuller reference.
#
#  grants.toml is the SOURCE OF TRUTH, applied deliberately: edit it, then run
#  `sudo gw policy apply`, which PREVIEWS the change (grant diff + tunnel
#  delta) and asks to confirm before signing it into policy.json. A policy
#  change tears down tunnels, so it is never applied silently. `gw policy show`
#  flags an edited-but-unapplied grants.toml.
#
#  Semantics — allow-only, and the table DERIVES the topology:
#    · a tunnel exists between two nodes iff some grant connects their roles
#      (either direction — tunnels are symmetric; direction matters to port
#      filtering, enforced by default; set enforce_ports=false to opt out)
#    · a node with no inbound grant is reachable by no one, yet is NOT isolated:
#      it can still DIAL OUT wherever a `from <me> -> to <them>` grant allows
#      (the reply rides the established tunnel)
#    · deleting a grant tears its tunnels down on the next sync + reconcile
#    · a deny rule is NOT expressible — omit the grant instead
#    · hardwired beneath the table, never editable here (policy must never sever
#      the channel that distributes policy):
#        every node <-> anchor  tcp/51902   the control plane (carries this file)
#        the enrollment door     tcp/51903   join-time only
#        established replies, ICMPv6
#
#  Built-in roles (CA-signed caps, assigned at invite / set-roles / set-caps):
#      node    every ordinary member (the default role for new nodes)
#      anchor  the single anchor host — RESERVED, never assignable to a joiner
#              (the anchor is its sole member); address it as `to = ["anchor"]`
#      admin   terminal access: hold it to SSH every node. The anchor holds it
#              by default; tag any box `role:admin` to add an operator.
#              (`*`, reach-all, is likewise reserved to the anchor.)
#      sudo gw invite --roles web            # → role:web (+ default caps)
#      sudo gw set-roles db01 db             # → role:db
#  Roles are the ONLY configured vocabulary. "Segments" are emergent: the
#  unnamed connected structure this table produces. `gw watch --by-role` reports
#  them; nothing configures them.
# ─────────────────────────────────────────────────────────────────────────────

# THE DEFAULT — DEFAULT-CLOSED, a secure star: the anchor (role:admin) can SSH
# every node, nodes reach only the anchor's control plane, and nodes cannot
# reach EACH OTHER at all. Open real services by ADDING grants below.
[[grant]]
from  = ["admin"]
to    = ["anchor", "node"]
ports = ["tcp/22"]

# ── Other baselines — uncomment one to REPLACE the grant above. ──────────────
#
# ALLOW EVERYTHING (flat mesh — identical to running with no policy, written out):
# [[grant]]
# from  = ["*"]
# to    = ["*"]
# ports = ["*"]
#
# SSH BETWEEN ALL NODES (lateral SSH — any node may SSH any other; looser than
# admin-only, it permits node-to-node movement):
# [[grant]]
# from  = ["node"]
# to    = ["node", "anchor"]
# ports = ["tcp/22"]
#
# ALLOW NOTHING is not a grant you write — it's the ABSENCE of grants: delete
# every [[grant]] and nodes reach ONLY the anchor (the hardwired control plane).

# ── Add service grants alongside the active one. A worked example: ───────────
#
# [[grant]]
# from  = ["web", "worker"]
# to    = ["api"]
# ports = ["tcp/8000"]
# # why: the app tier calls the API; nothing else does.
#
# [[grant]]
# from  = ["web"]
# to    = ["db"]
# ports = ["tcp/5432"]
# # why: only web reaches postgres — workers go through the API.
#
# [[grant]]
# from  = ["metrics"]
# to    = ["*"]                  # every node
# ports = ["tcp/9100"]
# # why: prometheus scrapes node_exporter fleet-wide (hub-and-spoke tunnels).
#
# [[grant]]
# from  = ["worker"]
# to    = ["files"]
# ports = ["tcp/2049"]
# # why: workers mount the NFS workspace on the role:files node. This grant IS
# #      the share's ACL — NFSv4 is single-port, so the exports file stays
# #      static (scoped to the overlay /64) and membership in role:worker
# #      decides who can mount. Full recipe: the README's NFS worked example.
