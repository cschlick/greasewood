# greasewood.toml — example configuration
# Copy to greasewood.toml and edit before running.

[node]
hostname = "mynode"
data_dir = "/var/lib/greasewood"

# "hub"   — holds ca_priv, serves the control plane + enrollment door, participates in mesh
# "node"  — plain mesh participant
role = "node"

# Can this node accept cold inbound WireGuard handshakes? (§8)
# "yes"     — open firewall, publicly reachable (cloud VMs, etc.)
# "no"      — behind stateful firewall; must initiate outward
# "unknown" — unsure (homelab with churny DHCPv6-PD)
inbound = "yes"

# Capability set for this node. mesh↔mesh links are allowed by default policy.
caps = ["mesh"]

# Explicit endpoints. Leave empty if you want WireGuard to discover via roaming.
# endpoints = ["[2001:db8::1]:51820"]


[network]
interface = "greasewood0"
listen_port = 51820

# Seeds to pull the directory from (HTTP).
# The root node is typically also a seed.
seeds = ["http://[fd8d:e5c1:db1a:7:XXXX:XXXX:XXXX:XXXX]:7946"]

# Where to send enroll/renew requests.
root_url = "http://[fd8d:e5c1:db1a:7:XXXX:XXXX:XXXX:XXXX]:7946"


[ca]
# Trusted CA public key(s) — raw Ed25519, hex-encoded.
# Build this as a SET from day one to allow CA migration (§11).
# Add both old and new keys during a migration overlap window.
# Get this value from `greasewood init-ca` on the root node.
trusted_pubs = [
    "REPLACE_WITH_HEX_PRINTED_BY_gw_setup-hub",
]


# Hub-only section — omit entirely on plain nodes.
# ("[root]" is accepted as an alias for backward compatibility.)
[hub]
ca_key_file = "/var/lib/greasewood/ca.key"
# Optionally protect the CA key with a passphrase (env var):
# ca_key_passphrase_env = "GREASEWOOD_CA_PASS"

# Address and port for the control plane HTTP server.
# Bind to the overlay address so traffic stays inside the tunnel.
# Example: "[fd8d:e5c1:db1a:7:XXXX:XXXX:XXXX:XXXX]:7946"
control_listen = ":7946"

# Credential lifetime. Revoking = not renewing; revoked node falls out
# fleet-wide when its last credential hits exp.
credential_ttl = "24h"

# Renewal is triggered at ~half the remaining TTL. With 24h TTL, nodes
# renew around the 12h mark, giving 12h of retry window before expiry.
renew_before = "12h"

# Enrollment flow (door-based — no SSH, no underlay HTTP):
#
#   1. On the hub:    TOKEN=$(sudo gw mint)
#                     (delivers a single-use token out of band)
#   2. On new node:   sudo gw join "$TOKEN" --hostname newnode
#                     sudo gw run
#      join receives a CA-signed credential over a transient WireGuard door;
#      run brings the node into the mesh and publishes its record to the hub.
#
# Manual alternative: `gw init-node` on the node, `gw issue` on the hub over
# SSH, then `gw install-cred` on the node.
