# greasewood.toml — example configuration
# Copy to greasewood.toml and edit before running.

[node]
# The node's mesh name. Chosen at `gw join` (defaults to the machine hostname)
# and changeable later with `gw rename` — UNLESS the anchor pinned it at invite
# (`gw invite --hostname …`), in which case this reflects the anchor's choice and
# rename is disabled. Either way it's CA-attested in the credential.
hostname = "mynode"
data_dir = "/var/lib/greasewood"

# "anchor"   — holds ca_priv, serves the control plane + enrollment door, participates in mesh
# "node"  — plain mesh participant
role = "node"

# (There is no "inbound" flag. Reachability is emergent: a node advertises an
# endpoint below or it doesn't. One that advertises none is naturally
# outbound-only — it dials peers; peers can't dial it. Peers back off a dead
# endpoint automatically, so a wrong guess just goes quiet, not noisy.)

# The node's tag set. Two kinds of tag live here:
#   roles — "role:<name>" is the grant-table vocabulary (`gw policy`). With no
#     policy applied every node peers (flat mesh); once a grant table exists,
#     tunnels derive from grants over these roles. "role:*" (the anchor)
#     reaches all, hardwired beneath any policy.
#   abilities — e.g. "tls" (may request TLS certs).
# Both are decided by the ANCHOR at `gw invite [--roles …] [--caps …]` and bound
# into the CA-signed credential — the joining node cannot choose its own. This
# line just reflects what the anchor issued; editing it grants nothing (peers
# enforce against your credential, not this file). To change: `gw set-roles`/
# `gw set-caps` on the anchor, or re-invite + re-join.
caps = ["role:mesh"]

# Underlay endpoint(s) other nodes dial to reach this one. The overlay is always
# IPv6, but the underlay may be IPv4 or IPv6 — list v4 and/or v6 (v6 bracketed).
# Usually set at join via --endpoint (needed for v4 behind 1:1 NAT, which
# can't be autodetected); leave empty for outbound-only nodes.
# endpoints = ["203.0.113.5:51900", "[2001:db8::1]:51900"]


[network]
interface = "gw-myfleet"
listen_port = 51900

# The fleet's overlay /64 (a ULA). Must be identical on every node in a mesh —
# a node learns it from its credential at join, so you normally only set this at
# create (--overlay-prefix). Give a DISTINCT prefix (and interface + ports +
# data_dir + config) to each mesh if one host is a node on two meshes at once.
overlay_prefix = "fd8d:e5c1:db1a:7::"

# Seeds to pull the directory from (HTTP).
# The anchor is typically also a seed.
seeds = ["http://[fd8d:e5c1:db1a:7:XXXX:XXXX:XXXX:XXXX]:51902"]

# Where to send enroll/renew requests.
root_url = "http://[fd8d:e5c1:db1a:7:XXXX:XXXX:XXXX:XXXX]:51902"

# Name resolution (ON by default). The daemon maintains a managed block in
# /etc/hosts mapping overlay addresses to "<hostname>.<mesh_domain>", so you can
# `ping db.myfleet.internal`. The domain is also the default TLS cert name from
# `gw cert-request`, so a node's address name matches its certificate SAN.
# It's namespaced under a dedicated ".myfleet.internal" so it can't shadow names an
# org already resolves via internal DNS for ".internal". Set hosts_sync=false
# (or `--no-hosts-sync`) to opt out; pick a distinct mesh_domain per fleet.
hosts_sync = true
mesh_domain = "myfleet.internal"

# Extra service names this node publishes, as bare labels under its OWN mesh
# name — each becomes "<label>.<hostname>.<mesh_domain>" in every node's
# /etc/hosts, pointing at this node. `gw cert-request` appends one automatically
# when a --san is a subdomain of this node's name (e.g. requesting a cert for
# pg.<hostname>.<mesh_domain> adds "pg"). Restart the daemon to advertise a change.
# aliases = ["pg", "metrics"]

# Durable data-plane command trail: the daemon appends every ip/wg command it
# issues (with exit code, timing, and why) to this rotating file, 0600. Default
# is <data_dir>/audit.log; set to "" to disable, or point it wherever you keep
# audit logs.
# audit_log = "/var/lib/greasewood/audit.log"


[ca]
# Trusted CA public key(s) — raw Ed25519, hex-encoded. This is the root of
# trust: a node accepts credentials only from a CA key listed here.
# It's a SET so you can move the CA by "re-rooting" — add the new key alongside
# the old during a migration overlap, then drop the old one fleet-wide.
# `gw create` prints this value (and join tokens carry it automatically).
trusted_pubs = [
    "REPLACE_WITH_HEX_PRINTED_BY_gw_create",
]


# Anchor-only section — omit entirely on plain nodes.
[anchor]
ca_key_file = "/var/lib/greasewood/ca.key"
# Optionally protect the CA key with a passphrase (env var):
# ca_key_passphrase_env = "GREASEWOOD_CA_PASS"

# Control-plane port (TCP). Bound only to the overlay + loopback, never the
# underlay. Nodes learn the value at enrollment, so it's safe to change here
# without touching any node config.
control_listen = ":51902"

# Enrollment door port (UDP). Carried in join tokens, so changing it just works
# for new tokens. Default is adjacent to the mesh port (51900/51901).
door_port = 51901

# Credential lifetime. Revoking = not renewing; revoked node falls out
# fleet-wide when its last credential hits exp.
credential_ttl = "24h"

# Renewal is triggered at ~half the remaining TTL. With 24h TTL, nodes
# renew around the 12h mark, giving 12h of retry window before expiry.
renew_before = "12h"

# Lifetime of x509 TLS service certs issued via `gw cert-request` (§12).
# Short-lived; the node daemon auto-renews each requested cert at ~half this TTL
# (and runs its --reload-cmd). Revocation is passive. This is an anchor-wide setting.
tls_cert_ttl = "7d"

# What NEW nodes get at `gw invite` when --roles/--caps are omitted. Read
# fresh at each invite, so editing these changes future enrollments with no
# restart (a per-invite --roles/--caps still overrides).
#   default_roles — the role(s) a new node holds. "mesh" is the conventional
#     default pool; rename it (e.g. ["core"]) to change what "the default" means.
#   default_caps     — abilities. Ships with "tls" ON. Set [] for TLS off-by-
#     default (a node can still be granted it later with `gw set-caps`).
default_roles = ["mesh"]
default_caps = ["tls"]

# Enrollment flow (door-based — no SSH, no underlay HTTP):
#
#   1. On the anchor:    TOKEN=$(sudo gw invite)
#                     (delivers a single-use token out of band)
#   2. On new node:   sudo gw join "$TOKEN" --hostname newnode
#                     sudo gw run
#      join receives a CA-signed credential over a transient WireGuard door;
#      run brings the node into the mesh and publishes its record to the anchor.
